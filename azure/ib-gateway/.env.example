# IBKR login (required)
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password

# paper | live
TRADING_MODE=paper

# accept | reject
TWS_ACCEPT_INCOMING=accept

# yes | no
READ_ONLY_API=no

# Optional 2FA behavior
# exit | restart
TWOFA_TIMEOUT_ACTION=exit
# yes | no
RELOGIN_AFTER_TWOFA_TIMEOUT=no
# if you have multiple devices configured, set explicit device name
TWOFA_DEVICE=

# Optional timezone for container
TIME_ZONE=UTC
